#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_BIN="$ROOT_DIR/.venv/bin"
PYTHONPATH_DIR="$ROOT_DIR/src"
ACTION="start"
PROXY_ARGS=()

if [[ $# -gt 0 ]]; then
  case "$1" in
    start|stop|restart|status|stats|bridge-key|help|-h|--help)
      ACTION="$1"
      shift
      ;;
    -*)
      PROXY_ARGS=("$@")
      ;;
    *)
      ACTION="$1"
      shift
      ;;
  esac
fi

pythonpath_env() {
  if [[ -n "${PYTHONPATH:-}" ]]; then
    printf '%s:%s' "$PYTHONPATH_DIR" "$PYTHONPATH"
  else
    printf '%s' "$PYTHONPATH_DIR"
  fi
}

start_proxy() {
  local -a cmd

  if [[ -x "$VENV_BIN/deepseek-cursor-proxy" ]]; then
    cmd=("$VENV_BIN/deepseek-cursor-proxy")
  elif command -v uv >/dev/null 2>&1; then
    cmd=(uv run deepseek-cursor-proxy)
  else
    echo "deepseek-cursor-proxy not found. Run 'uv sync' or install the package into .venv first." >&2
    exit 1
  fi

  exec env PYTHONPATH="$(pythonpath_env)" "${cmd[@]}" "$@"
}

stop_proxy() {
  if ! lsof -tiTCP:9000 -sTCP:LISTEN >/dev/null 2>&1; then
    echo "deepseek is not listening on port 9000"
  else
    pkill -f "deepseek-cursor-proxy" || true
  fi

  pkill -f 'ngrok http .*127\.0\.0\.1:9000' || true
  pkill -f 'ngrok http .*localhost:9000' || true

  for _ in {1..20}; do
    if ! lsof -tiTCP:9000 -sTCP:LISTEN >/dev/null 2>&1; then
      break
    fi
    sleep 0.25
  done
}

status_proxy() {
  if lsof -nP -iTCP:9000 -sTCP:LISTEN >/dev/null 2>&1; then
    lsof -nP -iTCP:9000 -sTCP:LISTEN
  else
    echo "deepseek is not listening on port 9000"
  fi
}

show_stats() {
  if [[ -x "$VENV_BIN/python" ]]; then
    exec env PYTHONPATH="$(pythonpath_env)" "$VENV_BIN/python" -m deepseek_cursor_proxy.stats "$@"
  elif command -v uv >/dev/null 2>&1; then
    exec env PYTHONPATH="$(pythonpath_env)" uv run python -m deepseek_cursor_proxy.stats "$@"
  fi
  echo "Python environment not found. Run 'uv sync' first." >&2
  exit 1
}

show_bridge_key() {
  if [[ -x "$VENV_BIN/python" ]]; then
    exec env PYTHONPATH="$(pythonpath_env)" "$VENV_BIN/python" -m deepseek_cursor_proxy.platform_summary
  elif command -v uv >/dev/null 2>&1; then
    exec env PYTHONPATH="$(pythonpath_env)" uv run python -m deepseek_cursor_proxy.platform_summary
  fi
  echo "Python environment not found. Run 'uv sync' first." >&2
  exit 1
}

is_proxy_running() {
  lsof -tiTCP:9000 -sTCP:LISTEN >/dev/null 2>&1
}

case "$ACTION" in
  start)
    if is_proxy_running; then
      echo "deepseek is already running on port 9000"
      echo "Use 'deepseek status' to inspect it or 'deepseek restart' to replace it."
      exit 1
    fi
    if [[ ${#PROXY_ARGS[@]} -eq 0 ]]; then
      start_proxy "$@"
    else
      start_proxy "${PROXY_ARGS[@]}"
    fi
    ;;
  stop)
    stop_proxy
    ;;
  restart)
    stop_proxy
    sleep 1
    if [[ ${#PROXY_ARGS[@]} -eq 0 ]]; then
      start_proxy "$@"
    else
      start_proxy "${PROXY_ARGS[@]}"
    fi
    ;;
  status)
    status_proxy
    ;;
  stats)
    show_stats "$@"
    ;;
  bridge-key)
    show_bridge_key
    ;;
  help|-h|--help)
    cat <<'EOF'
Usage:
  deepseek                Start the proxy
  deepseek start          Start the proxy
  deepseek stop           Stop the proxy
  deepseek restart        Restart the proxy
  deepseek status         Show whether port 9000 is in use
  deepseek stats          Show live account-wide platform usage from the browser bridge
  deepseek bridge-key     Print the local key used by the browser bridge

Examples:
  deepseek --verbose
  deepseek start --no-ngrok
  deepseek restart --ngrok-url https://your-subdomain.ngrok.dev
  deepseek stats --json
EOF
    ;;
  *)
    echo "Unknown command: $ACTION" >&2
    echo "Run 'deepseek --help' for usage." >&2
    exit 1
    ;;
esac
