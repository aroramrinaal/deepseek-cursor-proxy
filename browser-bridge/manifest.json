{
  "manifest_version": 3,
  "name": "DeepSeek Platform Usage Bridge",
  "version": "0.1.0",
  "description": "Forwards the visible DeepSeek Usage-page summary to your local DeepSeek Cursor proxy.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://platform.deepseek.com/*",
    "http://127.0.0.1:9000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://platform.deepseek.com/usage*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js"],
      "matches": ["https://platform.deepseek.com/*"]
    }
  ],
  "options_page": "options.html"
}
